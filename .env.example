# See https://dotenvx.com/v1 for all available options

# === DATABASE CONFIGURATION ===
# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/barbour?schema=public"

# === APPLICATION CONFIGURATION ===
# Nuxt app public runtime config
NUXT_PUBLIC_APP_NAME="Barbour Caisse"
NUXT_PUBLIC_API_BASE_URL="/api"

# === SERVER CONFIGURATION ===
# Node environment
NODE_ENV=development

# Server port
NUXT_PORT=3000

# Host binding (0.0.0.0 for all interfaces)
NUXT_HOST=0.0.0.0

# === PRISMA ===
# Prisma schema path (default)
PRISMA_SCHEMA_PATH=./prisma/schema.prisma

# === LOGGING ===
# Log level: silent, error, warn, info, debug
NUXT_LOG_LEVEL=info

# === SECURITY ===
# JWT secret for authentication (change in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Session secret
NUXT_SESSION_PASSWORD=your-session-secret-minimum-32-characters

# === OAUTH CONFIGURATION ===
# Google OAuth credentials (optional - for Google Sign-In)
NUXT_PUBLIC_GOOGLE_CLIENT_ID=
NUXT_GOOGLE_CLIENT_SECRET=
NUXT_GOOGLE_REDIRECT_URL=http://localhost:3000/auth/google/callback

# === EMAIL CONFIGURATION ===
# SMTP settings for notifications (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@barbour.com

# === PRODUCTION SETTINGS ===
# Enable HTTPS in development (optional)
NUXT_DEV_HTTPS=false

# Build optimization
NUXT_CSP=false

# === TRAEFIK PROXY CONFIGURATION ===
# Traefik entrypoints
TRAEFIK_HTTP_ENTRYPOINT=http:80
TRAEFIK_HTTPS_ENTRYPOINT=https:443

# Traefik network name
TRAEFIK_NETWORK=proxy

# Cloudflare SSL resolver
TRAEFIK_CLOUDFLARE_DNS_API_TOKEN=

# === PM2 CONFIGURATION ===
# PM2 instance count (set to max memory for cluster mode)
PM2_INSTANCES=max

# PM2 log directory
PM2_LOG_DIR=/var/log/pm2

# === BACKUP CONFIGURATION ===
# Backup directory (absolute path on server)
BACKUP_DIR=/opt/barbour/backups

# Backup retention (days)
BACKUP_RETENTION_DAYS=30

# Backup schedule (cron format)
BACKUP_SCHEDULE=0 2 * * *

# === MONITORING ===
# Health check endpoint
HEALTH_CHECK_INTERVAL=30

# Alert threshold (percentage)
ALERT_THRESHOLD=80
